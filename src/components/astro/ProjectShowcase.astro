---
import type { Project } from '@/types/content';
import Container from './Container.astro';
import dayjs from 'dayjs';

interface Props {
  projects: Project[];
}

const { projects } = Astro.props;
---

<div class="pw-list" data-animate-stagger>
  {projects.map((project, i) => {
    const img = project.thumbnail?.responsiveImage;
    const tagList = project.tags ? project.tags.split(/[,·]/).map(t => t.trim()).filter(Boolean) : [];
    const href = `/work/${project.slug}`;
    const indexLabel = String(i + 1).padStart(2, '0');
    const isEven = i % 2 === 1;
    const year = project.date ? dayjs(project.date as string).format('YYYY') : '';

    return (
      <a
        href={href}
        class:list={['pw-project', isEven && 'pw-project--flipped']}
        data-animate
      >
        <Container wide>
          <div class="pw-project-inner">
            {/* Image side */}
            {img && (
              <div class="pw-project-visual" transition:name={`card-${project.slug}`}>
                <div class="pw-project-img-wrap">
                  <img
                    src={img.src}
                    srcset={img.srcSet}
                    sizes="(min-width: 1024px) 55vw, 90vw"
                    width={img.width}
                    height={img.height}
                    alt={img.alt || project.title}
                    loading="lazy"
                    decoding="async"
                    class="pw-project-img"
                    style={img.base64 ? `background-image: url(${img.base64}); background-size: cover;` : ''}
                  />
                </div>
              </div>
            )}

            {/* Info side */}
            <div class="pw-project-info">
              <span class="pw-project-num" aria-hidden="true">{indexLabel}</span>
              <h3 class="pw-project-title">{project.title}</h3>
              {tagList.length > 0 && (
                <div class="pw-project-tags">
                  {tagList.map(tag => (
                    <span class="pw-project-tag">{tag}</span>
                  ))}
                </div>
              )}
              {year && <span class="pw-project-year">{year}</span>}
              <div class="pw-project-cta">
                <span class="pw-project-cta-text">View project</span>
                <svg class="pw-project-cta-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="7" y1="17" x2="17" y2="7" />
                  <polyline points="7 7 17 7 17 17" />
                </svg>
              </div>
            </div>
          </div>
        </Container>

        {/* Bottom accent line */}
        <div class="pw-project-accent" aria-hidden="true"></div>
      </a>
    );
  })}
</div>

<style>
  /* ===== PROJECT LIST ===== */
  .pw-list {
    margin-top: 2.5rem;
  }

  /* ===== SINGLE PROJECT ROW ===== */
  .pw-project {
    display: block;
    position: relative;
    border-top: 1px solid var(--border);
    transition: background 0.4s ease;
  }

  .pw-project:last-child {
    border-bottom: 1px solid var(--border);
  }

  .pw-project:hover {
    background: var(--bg-elevated);
  }

  .pw-project-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    padding: 3rem 0;
  }

  @media (min-width: 1024px) {
    .pw-project-inner {
      grid-template-columns: 1.15fr 0.85fr;
      gap: 3.5rem;
      align-items: center;
      padding: 4rem 0;
    }

    .pw-project--flipped .pw-project-inner {
      grid-template-columns: 0.85fr 1.15fr;
    }

    .pw-project--flipped .pw-project-visual {
      order: 2;
    }

    .pw-project--flipped .pw-project-info {
      order: 1;
    }
  }

  /* ===== IMAGE ===== */
  .pw-project-visual {
    position: relative;
    border-radius: var(--radius-xl);
    overflow: hidden;
    background: var(--bg-surface);
    border: 1px solid var(--border);
  }

  .pw-project-img-wrap {
    overflow: hidden;
    border-radius: inherit;
  }

  .pw-project-img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform;
  }

  .pw-project:hover .pw-project-img {
    transform: scale(1.04);
  }

  /* ===== INFO SIDE ===== */
  .pw-project-info {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .pw-project-num {
    font-family: 'Bricolage Grotesque', Georgia, serif;
    font-size: clamp(4rem, 8vw, 6.5rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--border);
    transition: color 0.4s ease;
    margin-bottom: 0.75rem;
  }

  .pw-project:hover .pw-project-num {
    color: var(--accent-glow-strong);
  }

  [data-theme="light"] .pw-project:hover .pw-project-num {
    color: color-mix(in srgb, var(--accent) 20%, transparent);
  }

  .pw-project-title {
    font-family: 'Bricolage Grotesque', Georgia, serif;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--text);
    transition: color 0.3s ease;
  }

  .pw-project:hover .pw-project-title {
    color: var(--accent);
  }

  .pw-project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 1rem;
  }

  .pw-project-tag {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.6875rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent);
    background: var(--accent-glow);
    padding: 0.25rem 0.7rem;
    border-radius: 100px;
    border: 1px solid transparent;
    transition: all 0.3s ease;
  }

  .pw-project:hover .pw-project-tag {
    background: var(--accent-glow-strong);
    border-color: color-mix(in srgb, var(--accent) 25%, transparent);
  }

  .pw-project-year {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8125rem;
    color: var(--text-muted);
    letter-spacing: 0.04em;
    margin-top: 1rem;
  }

  /* CTA link */
  .pw-project-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1.75rem;
    color: var(--text-muted);
    transition: color 0.3s ease;
  }

  .pw-project:hover .pw-project-cta {
    color: var(--accent);
  }

  .pw-project-cta-text {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  .pw-project-cta-arrow {
    transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .pw-project:hover .pw-project-cta-arrow {
    transform: translate(3px, -3px);
  }

  /* Accent line at bottom */
  .pw-project-accent {
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--gradient-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .pw-project:hover .pw-project-accent {
    transform: scaleX(1);
  }

  /* ===== MOBILE ===== */
  @media (max-width: 767px) {
    .pw-project-inner {
      padding: 2rem 0;
      gap: 1.25rem;
    }

    .pw-project-num {
      font-size: 3rem;
      margin-bottom: 0.25rem;
    }
  }

  /* ===== TOUCH ===== */
  @media (hover: none) and (pointer: coarse) {
    .pw-project:hover {
      background: transparent;
    }

    .pw-project:hover .pw-project-img {
      transform: none;
    }

    .pw-project:hover .pw-project-title {
      color: var(--text);
    }

    .pw-project:hover .pw-project-num {
      color: var(--border);
    }

    .pw-project:active {
      opacity: 0.85;
      transition: opacity 0.1s ease;
    }

    .pw-project-cta {
      color: var(--accent);
    }

    .pw-project-accent {
      transform: scaleX(1);
      opacity: 0.3;
    }
  }

  /* ===== REDUCED MOTION ===== */
  @media (prefers-reduced-motion: reduce) {
    .pw-project-img,
    .pw-project-accent,
    .pw-project-cta-arrow,
    .pw-project-num,
    .pw-project-title,
    .pw-project-tag,
    .pw-project-cta,
    .pw-project {
      transition-duration: 0.01ms !important;
    }
  }
</style>
