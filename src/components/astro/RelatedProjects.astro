---
import type { Project } from '@/types/content';

interface Props {
  projects: Project[];
}

const { projects } = Astro.props;
---

<div class="rp-list" data-animate-stagger>
  {projects.map((project, i) => {
    const img = project.thumbnail?.responsiveImage;
    const href = `/work/${project.slug}`;
    const tagList = project.tags ? project.tags.split(/[,·]/).map(t => t.trim()).filter(Boolean) : [];
    const num = String(i + 1).padStart(2, '0');

    return (
      <a href={href} class="rp-item" data-animate>
        <span class="rp-index">{num}</span>

        <div class="rp-preview">
          {img && (
            <img
              src={img.src}
              srcset={img.srcSet}
              sizes="80px"
              width={img.width}
              height={img.height}
              alt={img.alt || project.title}
              loading="lazy"
              decoding="async"
              class="rp-img"
              style={img.base64 ? `background-image: url(${img.base64}); background-size: cover;` : ''}
            />
          )}
        </div>

        <div class="rp-content">
          <h4 class="rp-title">{project.title}</h4>
          {tagList.length > 0 && (
            <div class="rp-tags">
              {tagList.map((tag, ti) => (
                <Fragment>
                  {ti > 0 && <span class="rp-dot" aria-hidden="true">&middot;</span>}
                  <span class="rp-tag">{tag}</span>
                </Fragment>
              ))}
            </div>
          )}
        </div>

        <svg class="rp-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M7 17L17 7M17 7H8M17 7v9" />
        </svg>

        <div class="rp-line" aria-hidden="true"></div>
      </a>
    );
  })}
</div>

<style>
  .rp-list {
    display: flex;
    flex-direction: column;
  }

  .rp-item {
    display: grid;
    grid-template-columns: 2rem 3.5rem 1fr 1.5rem;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 0;
    text-decoration: none;
    position: relative;
    border-top: 1px solid var(--border);
  }

  .rp-item:last-child {
    border-bottom: 1px solid var(--border);
  }

  /* Index number */
  .rp-index {
    font-family: 'JetBrains Mono', 'SF Mono', monospace;
    font-size: 0.6875rem;
    font-weight: 400;
    color: var(--text-muted);
    letter-spacing: 0.02em;
    transition: color 0.4s ease;
  }

  .rp-item:hover .rp-index {
    color: var(--accent);
  }

  /* Thumbnail */
  .rp-preview {
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 0.625rem;
    overflow: hidden;
    background: var(--bg-surface);
    flex-shrink: 0;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .rp-item:hover .rp-preview {
    transform: scale(1.08);
  }

  .rp-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .rp-item:hover .rp-img {
    transform: scale(1.1);
  }

  /* Content */
  .rp-content {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
  }

  .rp-title {
    font-family: 'Bricolage Grotesque', Georgia, serif;
    font-weight: 600;
    font-size: 0.9375rem;
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--text);
    transition: color 0.3s ease;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .rp-item:hover .rp-title {
    color: var(--accent);
  }

  .rp-tags {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.25rem;
  }

  .rp-tag {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.625rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted);
  }

  .rp-dot {
    color: var(--border-hover);
    font-size: 0.75rem;
  }

  /* Arrow */
  .rp-arrow {
    width: 1rem;
    height: 1rem;
    color: var(--text-muted);
    opacity: 0;
    transform: translate(-4px, 4px);
    transition:
      opacity 0.3s ease,
      transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      color 0.3s ease;
  }

  .rp-item:hover .rp-arrow {
    opacity: 1;
    transform: translate(0, 0);
    color: var(--accent);
  }

  /* Bottom accent line on hover */
  .rp-line {
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--gradient-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .rp-item:hover .rp-line {
    transform: scaleX(1);
  }

  /* Touch */
  @media (hover: none) and (pointer: coarse) {
    .rp-item:hover .rp-preview {
      transform: none;
    }

    .rp-item:hover .rp-img {
      transform: none;
    }

    .rp-item:hover .rp-title {
      color: var(--text);
    }

    .rp-item:hover .rp-index {
      color: var(--text-muted);
    }

    .rp-arrow {
      opacity: 0.4;
      transform: translate(0, 0);
    }

    .rp-item:hover .rp-arrow {
      color: var(--text-muted);
    }

    .rp-line {
      transform: scaleX(1);
      opacity: 0.3;
    }

    .rp-item:active {
      opacity: 0.8;
      transition: opacity 0.1s ease;
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .rp-item,
    .rp-preview,
    .rp-img,
    .rp-arrow,
    .rp-line,
    .rp-index {
      transition-duration: 0.01ms !important;
    }
  }
</style>
