---
const row1Cards = [
  {
    quote: "His passion for UX and UI design combined with his passion for web development is a deadly combination. He can convert any low-fidelity wireframe into a beautiful looking end product.",
    name: 'Bapusaheb Patil',
    role: 'Head of AI & Design Engineering',
    company: 'Fluence',
    emoji: '🎨',
    accent: '249, 115, 22',
  },
  {
    quote: "One of the finest and most creative UI Developers I've interacted with. He has the acumen to recreate your designs flawlessly and suggest improvements.",
    name: 'Nikhil Suresh',
    role: 'Senior Software Engineer',
    company: 'Morningstar',
    emoji: '✨',
    accent: '59, 130, 246',
  },
  {
    quote: "It was amazing to work with him — the work was remote and there was no setback. I would definitely recommend it!",
    name: 'José Mosso',
    role: 'Co-Founder',
    company: 'Homero',
    emoji: '🚀',
    accent: '16, 185, 129',
  },
  {
    quote: "He invests a lot of time coming up with amazing UI designs and would definitely be an asset to any company. His skills in React and UI design are amazing and rare to find in one.",
    name: 'Gautam Krishnan',
    role: 'SWE (IC-3)',
    company: 'ServiceNow',
    emoji: '💡',
    accent: '168, 85, 247',
  },
];

const row2Cards = [
  {
    quote: "His technical proficiency and domain expertise are remarkable. What sets him apart is his ability to swiftly make decisions, never compromising on quality or efficiency.",
    name: 'Akshay Bhat',
    role: 'Product Manager',
    company: 'Yellow.ai',
    emoji: '⚡',
    accent: '234, 179, 8',
  },
  {
    quote: "He designs excellent front end for web and his concern to keep the UI and UX the best is an add-on. If you are seeking a web developer or a front end specialist, Adithya would be the best choice.",
    name: 'Madana Krishnan',
    role: 'Senior Data Scientist 2',
    company: 'Quantumblack, McKinsey',
    emoji: '🔮',
    accent: '236, 72, 153',
  },
  {
    quote: "It's rare to come across a standout talent like Adithya. I have worked with him on a few projects and I'm amazed at his work. He's a good asset for any company.",
    name: 'Saiprasanth R.',
    role: 'Principal Engineer',
    company: 'Navatech',
    emoji: '🏆',
    accent: '245, 158, 11',
  },
];

/* Duplicate each row for seamless CSS loop */
const track1 = [...row1Cards, ...row1Cards];
const track2 = [...row2Cards, ...row2Cards];
---

<div class="wall">
  {/* Row 1 — scrolls left */}
  <div class="wall-row" aria-label="Testimonials">
    <div class="wall-track wall-track--left">
      {track1.map((t) => (
        <blockquote class="wall-card" style={`--card-accent: ${t.accent}`}>
          <div class="wall-card-glow" aria-hidden="true"></div>
          <span class="wall-emoji" aria-hidden="true">{t.emoji}</span>
          <p class="wall-quote">{t.quote}</p>
          <footer class="wall-who">
            <span class="wall-name">{t.name}</span>
            <span class="wall-role">{t.role} <span class="wall-at">@</span> {t.company}</span>
          </footer>
        </blockquote>
      ))}
    </div>
  </div>

  {/* Row 2 — scrolls right (different people) */}
  <div class="wall-row">
    <div class="wall-track wall-track--right">
      {track2.map((t) => (
        <blockquote class="wall-card" style={`--card-accent: ${t.accent}`}>
          <div class="wall-card-glow" aria-hidden="true"></div>
          <span class="wall-emoji" aria-hidden="true">{t.emoji}</span>
          <p class="wall-quote">{t.quote}</p>
          <footer class="wall-who">
            <span class="wall-name">{t.name}</span>
            <span class="wall-role">{t.role} <span class="wall-at">@</span> {t.company}</span>
          </footer>
        </blockquote>
      ))}
    </div>
  </div>
</div>

<style>
  /* ===== Wall container ===== */
  .wall {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    overflow: hidden;
    padding: 1rem 0;
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 6%,
      black 94%,
      transparent 100%
    );
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 6%,
      black 94%,
      transparent 100%
    );
  }

  .wall-row {
    width: 100%;
    overflow: hidden;
    padding: 12px 0;
    margin: -12px 0;
  }

  /* ===== Track — infinite scroll ===== */
  .wall-track {
    display: flex;
    gap: 1rem;
    width: max-content;
  }

  .wall-track--left {
    animation: marqueeLeft 50s linear infinite;
  }

  .wall-track--right {
    animation: marqueeRight 45s linear infinite;
  }

  @keyframes marqueeLeft {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  @keyframes marqueeRight {
    from { transform: translateX(-50%); }
    to   { transform: translateX(0); }
  }

  /* Pause on hover */
  .wall:hover .wall-track {
    animation-play-state: paused;
  }

  /* ===== Card ===== */
  .wall-card {
    position: relative;
    width: 300px;
    flex-shrink: 0;
    padding: 1.25rem 1.25rem 1rem;
    border-radius: var(--radius-xl);
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    overflow: hidden;
    transition:
      border-color 0.3s ease,
      transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1),
      box-shadow 0.4s ease;
  }

  .wall-card:hover {
    border-color: rgba(var(--card-accent), 0.4);
    transform: translateY(-6px) scale(1.02);
    box-shadow:
      0 20px 40px -10px rgba(0, 0, 0, 0.3),
      0 0 20px -5px rgba(var(--card-accent), 0.15);
    z-index: 2;
  }

  /* Colored glow blob in top-right */
  .wall-card-glow {
    position: absolute;
    top: -30px;
    right: -30px;
    width: 100px;
    height: 100px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(var(--card-accent), 0.12) 0%,
      transparent 70%
    );
    pointer-events: none;
    transition: opacity 0.4s ease;
  }

  .wall-card:hover .wall-card-glow {
    opacity: 1.5;
  }

  /* Top accent line */
  .wall-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(var(--card-accent), 0.6),
      transparent
    );
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .wall-card:hover::before {
    opacity: 1;
  }

  .wall-emoji {
    font-size: 1.375rem;
    line-height: 1;
    position: relative;
    z-index: 1;
  }

  .wall-quote {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.8125rem;
    line-height: 1.7;
    color: var(--text-secondary);
    flex: 1;
    position: relative;
    z-index: 1;
  }

  /* ===== Footer ===== */
  .wall-who {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border);
    position: relative;
    z-index: 1;
  }

  .wall-name {
    font-family: 'Bricolage Grotesque', Georgia, serif;
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.3;
  }

  .wall-role {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.6875rem;
    color: var(--text-muted);
    line-height: 1.3;
  }

  .wall-at {
    color: rgba(var(--card-accent), 1);
    font-weight: 600;
  }

  /* ===== Responsive ===== */
  @media (max-width: 767px) {
    .wall-card {
      width: 260px;
      padding: 1rem;
    }

    .wall-quote {
      font-size: 0.75rem;
    }

    .wall-track--left {
      animation-duration: 35s;
    }

    .wall-track--right {
      animation-duration: 30s;
    }
  }

  /* ===== Touch ===== */
  @media (hover: none) and (pointer: coarse) {
    .wall-card:hover {
      transform: none;
      box-shadow: none;
      border-color: var(--border);
    }

    .wall:hover .wall-track {
      animation-play-state: running;
    }
  }

  /* ===== Reduced motion ===== */
  @media (prefers-reduced-motion: reduce) {
    .wall-track {
      animation: none !important;
    }

    .wall-card {
      transition-duration: 0.01ms !important;
    }

    .wall {
      -webkit-mask-image: none;
      mask-image: none;
    }

    .wall-row {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }

    .wall-row::-webkit-scrollbar {
      display: none;
    }
  }
</style>
