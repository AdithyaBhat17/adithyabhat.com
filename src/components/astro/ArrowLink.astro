---
interface Props {
  href: string;
  text: string;
}

const { href, text } = Astro.props;
---

<a href={href} class="arrow-link">
  <span class="arrow-link-text">{text}</span>
  <span class="arrow-link-icon" aria-hidden="true">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <line x1="5" y1="12" x2="19" y2="12" />
      <polyline points="12 5 19 12 12 19" />
    </svg>
  </span>
</a>

<style>
  .arrow-link {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 2.5rem;
    padding: 0.75rem 1.5rem 0.75rem 1.25rem;
    border-radius: 100px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-secondary);
    text-decoration: none;
    cursor: pointer;
    transition:
      color 0.3s ease,
      border-color 0.3s ease,
      background 0.3s ease,
      box-shadow 0.4s ease;
  }

  .arrow-link:hover {
    color: var(--accent);
    border-color: color-mix(in srgb, var(--accent) 40%, transparent);
    background: var(--accent-glow);
    box-shadow: 0 0 20px -4px color-mix(in srgb, var(--accent) 15%, transparent);
  }

  .arrow-link-text {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  .arrow-link-icon {
    display: flex;
    align-items: center;
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .arrow-link:hover .arrow-link-icon {
    transform: translateX(4px);
  }

  /* Touch */
  @media (hover: none) and (pointer: coarse) {
    .arrow-link {
      color: var(--accent);
      border-color: color-mix(in srgb, var(--accent) 25%, transparent);
    }

    .arrow-link:hover {
      background: transparent;
      box-shadow: none;
    }

    .arrow-link:active {
      opacity: 0.7;
      transition: opacity 0.1s ease;
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .arrow-link,
    .arrow-link-icon {
      transition-duration: 0.01ms !important;
    }
  }
</style>
