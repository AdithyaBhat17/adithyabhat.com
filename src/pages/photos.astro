---
import PageLayout from '@/layouts/PageLayout.astro';
import PhotoGallery from '@/components/react/PhotoGallery';
import FloatingShapes from '@/components/astro/FloatingShapes.astro';
import { fetchGalleryAPI } from '@/lib/datocms';
import { GALLERY_PHOTOS } from '@/graphql/photos';

const data = await fetchGalleryAPI(GALLERY_PHOTOS);
const places = data.allPlaces ?? [];
const totalPhotos = places.reduce((sum: number, p: any) => sum + (p.photos?.length ?? 0), 0);

// Get unique states/regions for display
const uniqueStates = [...new Set(places.map((p: any) => p.state).filter(Boolean))];
// Get cameras used
const cameras = [...new Set(places.map((p: any) => p.camera).filter(Boolean))];
---

<PageLayout title="Photos | Adithya NR">
  <div class="photos-page">
    <FloatingShapes />

    <!-- Hero header -->
    <div class="photos-header" data-animate>
      <div class="photos-header-inner">
        <span class="inline-flex items-center gap-2 text-sm font-body font-medium text-[var(--accent)] tracking-wide uppercase mb-5">
          <span class="inline-block w-6 h-[2px] bg-[var(--accent)]"></span>
          Gallery
        </span>

        <h1 class="font-display text-4xl md:text-5xl lg:text-6xl tracking-tight leading-[1.1]">
          Through my<br />
          <span class="gradient-text">lens</span>
          <span class="camera-icon" aria-hidden="true">&#x1F4F7;</span>
        </h1>

        <p class="font-body text-[var(--text-secondary)] mt-4 text-lg leading-relaxed max-w-lg">
          Snapshots from my travels and everyday life. Landscapes,
          cityscapes, and everything in between.
        </p>
      </div>

      <!-- Stats row -->
      <div class="stats-row" data-animate>
        <div class="stat-item">
          <span class="stat-number font-display">{totalPhotos}</span>
          <span class="stat-label font-body">photos</span>
        </div>
        <div class="stat-divider" aria-hidden="true"></div>
        <div class="stat-item">
          <span class="stat-number font-display">{places.length}</span>
          <span class="stat-label font-body">places</span>
        </div>
        <div class="stat-divider" aria-hidden="true"></div>
        <div class="stat-item">
          <span class="stat-number font-display">{uniqueStates.length}</span>
          <span class="stat-label font-body">states</span>
        </div>
        {cameras.length > 0 && (
          <>
            <div class="stat-divider" aria-hidden="true"></div>
            <div class="stat-item">
              <span class="stat-number font-display">{cameras.length}</span>
              <span class="stat-label font-body">{cameras.length === 1 ? 'camera' : 'cameras'}</span>
            </div>
          </>
        )}
      </div>
    </div>

    <!-- Gallery -->
    <div class="photos-gallery">
      <PhotoGallery places={places} client:load />
    </div>
  </div>
</PageLayout>

<style>
  .photos-page {
    position: relative;
    padding: 0 1.5rem 4rem;
    max-width: 1400px;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .photos-page {
      padding: 0 4rem 6rem;
    }
  }

  /* ===== HEADER ===== */
  .photos-header {
    position: relative;
    z-index: 1;
    padding: 1rem 0 2.5rem;
  }

  .photos-header-inner {
    max-width: 640px;
  }

  /* ===== CAMERA ICON ===== */
  .camera-icon {
    display: inline-flex;
    margin-left: 0.375rem;
    color: var(--accent);
    vertical-align: middle;
    animation: shutter 3s ease-in-out infinite;
  }

  @keyframes shutter {
    0%, 100% { transform: rotate(0deg); }
    8% { transform: rotate(-8deg) scale(1.1); }
    16% { transform: rotate(0deg) scale(1); }
  }

  /* ===== STATS ROW ===== */
  .stats-row {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-top: 2rem;
    padding: 1.25rem 1.5rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    width: fit-content;
    flex-wrap: wrap;
  }

  .stat-item {
    display: flex;
    align-items: baseline;
    gap: 0.375rem;
  }

  .stat-number {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .stat-label {
    font-size: 0.8125rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  .stat-divider {
    width: 1px;
    height: 24px;
    background: var(--border);
  }

  /* ===== GALLERY ===== */
  .photos-gallery {
    position: relative;
    z-index: 1;
    margin-top: 1rem;
  }

  /* ===== REDUCED MOTION ===== */
  @media (prefers-reduced-motion: reduce) {
    .camera-icon {
      animation: none;
    }
  }

  @media (max-width: 480px) {
    .stats-row {
      gap: 0.75rem;
      padding: 1rem 1.25rem;
    }

    .stat-number {
      font-size: 1.25rem;
    }

    .stat-divider {
      height: 20px;
    }
  }
</style>
