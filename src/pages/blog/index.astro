---
import PageLayout from '@/layouts/PageLayout.astro';
import Container from '@/components/astro/Container.astro';
import CardGrid from '@/components/astro/CardGrid.astro';
import FloatingShapes from '@/components/astro/FloatingShapes.astro';
import { fetchAPI } from '@/lib/datocms';
import { ALL_ARTICLES_QUERY } from '@/graphql/posts';

const data = await fetchAPI(ALL_ARTICLES_QUERY);
const articles = data.allArticles ?? [];

// Collect all unique tags
const allTags = [...new Set(
  articles.flatMap((a: any) => a.tags ? a.tags.split(/[,·]/).map((t: string) => t.trim()).filter(Boolean) : [])
)];
---

<PageLayout title="Blog | Adithya NR">
  <div class="blog-page">
    <FloatingShapes />

    <Container>
      <!-- Header -->
      <div class="blog-header" data-animate>
        <div class="blog-header-inner">
          <span class="inline-flex items-center gap-2 text-sm font-body font-medium text-[var(--accent)] tracking-wide uppercase mb-5">
            <span class="inline-block w-6 h-[2px] bg-[var(--accent)]"></span>
            Blog
          </span>

          <h1 class="font-display text-4xl md:text-5xl lg:text-6xl tracking-tight leading-[1.1]">
            Thoughts &<br />
            <span class="gradient-text">writings</span>
            <span class="pen-icon" aria-hidden="true">&#x270F;&#xFE0F;</span>
          </h1>

          <p class="font-body text-[var(--text-secondary)] mt-4 text-lg leading-relaxed max-w-lg">
            Notes on design, development, and things I find interesting along the way.
          </p>
        </div>

        <!-- Stats + tags row -->
        <div class="blog-meta" data-animate>
          <div class="blog-stats">
            <span class="stat-number font-display">{articles.length}</span>
            <span class="stat-label font-body">{articles.length === 1 ? 'article' : 'articles'}</span>
          </div>

          {allTags.length > 0 && (
            <div class="blog-tags">
              {allTags.slice(0, 8).map((tag) => (
                <span class="blog-tag">{tag}</span>
              ))}
            </div>
          )}
        </div>
      </div>

      <!-- Articles grid -->
      <CardGrid items={articles} type="article" />
    </Container>
  </div>
</PageLayout>

<style>
  .blog-page {
    position: relative;
  }

  /* ===== HEADER ===== */
  .blog-header {
    position: relative;
    z-index: 1;
    padding-top: 2rem;
    margin-bottom: 0.5rem;
  }

  .blog-header-inner {
    max-width: 640px;
  }

  /* ===== PEN ICON ===== */
  .pen-icon {
    display: inline-block;
    margin-left: 0.25rem;
    animation: scribble 3s ease-in-out infinite;
    transform-origin: bottom left;
  }

  @keyframes scribble {
    0%, 100% { transform: rotate(0deg); }
    10% { transform: rotate(-12deg); }
    20% { transform: rotate(5deg); }
    30% { transform: rotate(-5deg); }
    40% { transform: rotate(0deg); }
  }

  /* ===== META ROW ===== */
  .blog-meta {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-top: 2rem;
    padding: 1rem 1.5rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    width: fit-content;
    max-width: 100%;
    flex-wrap: wrap;
  }

  .blog-stats {
    display: flex;
    align-items: baseline;
    gap: 0.375rem;
    flex-shrink: 0;
  }

  .stat-number {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .stat-label {
    font-size: 0.8125rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  /* ===== TAGS ===== */
  .blog-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    border-left: 1px solid var(--border);
    padding-left: 1.25rem;
  }

  .blog-tag {
    display: inline-block;
    padding: 0.2rem 0.65rem;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--accent);
    background: var(--accent-glow);
    border-radius: 100px;
    letter-spacing: 0.02em;
  }

  @media (max-width: 480px) {
    .blog-meta {
      gap: 0.75rem;
      padding: 1rem 1.25rem;
    }

    .blog-tags {
      border-left: none;
      padding-left: 0;
      border-top: 1px solid var(--border);
      padding-top: 0.75rem;
      width: 100%;
    }

    .stat-number {
      font-size: 1.25rem;
    }
  }

  /* ===== REDUCED MOTION ===== */
  @media (prefers-reduced-motion: reduce) {
    .pen-icon {
      animation: none;
    }
  }
</style>
