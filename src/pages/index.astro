---
import PageLayout from '@/layouts/PageLayout.astro';
import Hero from '@/components/astro/Hero.astro';
import Container from '@/components/astro/Container.astro';
import FeaturedArticles from '@/components/astro/FeaturedArticles.astro';
import ProjectShowcase from '@/components/astro/ProjectShowcase.astro';
import ArrowLink from '@/components/astro/ArrowLink.astro';
import Testimonials from '@/components/astro/Testimonials.astro';
import { fetchAPI } from '@/lib/datocms';
import { HOME_PAGE_QUERY } from '@/graphql/index';

const data = await fetchAPI(HOME_PAGE_QUERY);
const projects = data.allProjects?.slice(0, 3) ?? [];
const articles = data.allArticles?.slice(0, 3) ?? [];
---

<PageLayout title="Adithya NR | A UX Engineer based in Abu Dhabi, UAE.">
  <Hero />

  <!-- Recent Work -->
  <section style="content-visibility:auto;contain-intrinsic-size:auto 800px;">
    <Container>
      <div class="section-head mt-16 md:mt-24 xl:mt-32 mb-6 md:mb-8" data-animate>
        <h2 class="sh-text">
          <span class="sh-quiet">Some of my</span>
          <span class="sh-loud">
            <span class="sh-highlight">selected</span> work<span class="sh-dot">.</span>
          </span>
        </h2>
        <span class="sh-count">{String(projects.length).padStart(2, '0')} projects</span>
      </div>
    </Container>
    <ProjectShowcase projects={projects} />
    <Container>
      <ArrowLink href="/work" text="View all projects" />
    </Container>
  </section>

  <!-- Featured Articles -->
  <section style="content-visibility:auto;contain-intrinsic-size:auto 600px;">
    <Container>
      <div class="section-head mt-16 md:mt-28 xl:mt-36 mb-6 md:mb-8" data-animate>
        <h2 class="sh-text">
          <span class="sh-quiet">Things I've been</span>
          <span class="sh-loud">
            writing<span class="sh-dot">.</span>
          </span>
        </h2>
      </div>
      <FeaturedArticles articles={articles} />
      <ArrowLink href="/blog" text="Read more articles" />
    </Container>
  </section>

  <!-- Testimonials -->
  <section style="content-visibility:auto;contain-intrinsic-size:auto 500px;">
    <Container>
      <div class="testimonial-heading mt-16 md:mt-28 xl:mt-36 mb-6 md:mb-8" data-animate>
        <h2 class="testimonial-heading-text">
          <span class="th-line1">Don't just take</span>
          <span class="th-line2">
            <span class="th-my">my</span>
            <span class="th-word-for-it">word for it</span>
            <span class="th-arrow" aria-hidden="true">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M7 7l10 10M17 7v10H7" />
              </svg>
            </span>
          </span>
        </h2>
      </div>
    </Container>
    <Testimonials />
  </section>

  <!-- CTA -->
  <section class="cta-section mt-16 md:mt-28 xl:mt-36 mb-12 md:mb-20 overflow-hidden" style="content-visibility:auto;contain-intrinsic-size:auto 500px;">
    <!-- Scrolling marquee (two identical tracks for seamless loop) -->
    <div class="cta-marquee-wrap" aria-hidden="true">
      <div class="cta-marquee">
        <div class="cta-marquee-track">
          <span>LET'S TALK&nbsp;&nbsp;&middot;&nbsp;&nbsp;</span>
          <span>GOT A PROJECT?&nbsp;&nbsp;&middot;&nbsp;&nbsp;</span>
          <span>LET'S TALK&nbsp;&nbsp;&middot;&nbsp;&nbsp;</span>
          <span>GOT A PROJECT?&nbsp;&nbsp;&middot;&nbsp;&nbsp;</span>
          <span>LET'S TALK&nbsp;&nbsp;&middot;&nbsp;&nbsp;</span>
          <span>GOT A PROJECT?&nbsp;&nbsp;&middot;&nbsp;&nbsp;</span>
          <span>LET'S TALK&nbsp;&nbsp;&middot;&nbsp;&nbsp;</span>
          <span>GOT A PROJECT?&nbsp;&nbsp;&middot;&nbsp;&nbsp;</span>
        </div>
        <div class="cta-marquee-track">
          <span>LET'S TALK&nbsp;&nbsp;&middot;&nbsp;&nbsp;</span>
          <span>GOT A PROJECT?&nbsp;&nbsp;&middot;&nbsp;&nbsp;</span>
          <span>LET'S TALK&nbsp;&nbsp;&middot;&nbsp;&nbsp;</span>
          <span>GOT A PROJECT?&nbsp;&nbsp;&middot;&nbsp;&nbsp;</span>
          <span>LET'S TALK&nbsp;&nbsp;&middot;&nbsp;&nbsp;</span>
          <span>GOT A PROJECT?&nbsp;&nbsp;&middot;&nbsp;&nbsp;</span>
          <span>LET'S TALK&nbsp;&nbsp;&middot;&nbsp;&nbsp;</span>
          <span>GOT A PROJECT?&nbsp;&nbsp;&middot;&nbsp;&nbsp;</span>
        </div>
      </div>
    </div>

    <Container>
      <div class="cta-card relative py-14 md:py-28 px-6 md:px-16 rounded-2xl bg-[var(--bg-elevated)] border border-[var(--border)] overflow-hidden" data-animate style="--cta-x:50%;--cta-y:50%;">
        <!-- Cursor glow -->
        <div class="cta-spotlight" aria-hidden="true"></div>

        <!-- Decorative shapes -->
        <div class="cta-shape cta-shape-1" aria-hidden="true"></div>
        <div class="cta-shape cta-shape-2" aria-hidden="true"></div>

        <h2 class="cta-heading font-display tracking-tight leading-[1.05] relative z-10">
          Got something<br/>in mind?
        </h2>
        <p class="font-body text-xl text-[var(--text-secondary)] mt-6 relative z-10 max-w-md">
          Whether it's a project, a question, or just to say hello —
        </p>
        <a href="/contact" class="btn-primary mt-10 relative z-10" data-magnetic>Let's talk</a>
      </div>
    </Container>
  </section>

  <style>
    /* ===== MARQUEE ===== */
    .cta-marquee-wrap {
      overflow: hidden;
      white-space: nowrap;
      padding: 1rem 0;
      margin-bottom: 1.5rem;
    }

    .cta-marquee {
      display: flex;
      width: max-content;
      animation: marqueeScroll 30s linear infinite;
    }

    .cta-marquee-track {
      display: flex;
      flex-shrink: 0;
    }

    .cta-marquee-track span {
      font-family: 'Bricolage Grotesque', Georgia, serif;
      font-size: clamp(0.875rem, 1.5vw, 1.125rem);
      font-weight: 700;
      letter-spacing: 0.15em;
      color: var(--text-muted);
      opacity: 0.3;
      white-space: nowrap;
    }

    @keyframes marqueeScroll {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }

    /* ===== CTA CARD ===== */
    .cta-heading {
      font-size: clamp(2.5rem, 7vw, 5rem);
    }

    /* Cursor spotlight */
    .cta-spotlight {
      position: absolute;
      inset: 0;
      background: radial-gradient(
        500px circle at var(--cta-x) var(--cta-y),
        var(--accent-glow) 0%,
        transparent 50%
      );
      pointer-events: none;
      z-index: 1;
      opacity: 0;
      transition: opacity 0.4s ease;
    }

    .cta-card:hover .cta-spotlight {
      opacity: 1;
    }

    /* Decorative shapes */
    .cta-shape {
      position: absolute;
      border: 1.5px solid var(--accent);
      opacity: 0.08;
      pointer-events: none;
    }

    .cta-shape-1 {
      width: 80px;
      height: 80px;
      border-radius: 50%;
      top: -20px;
      right: 10%;
      animation: ctaFloat1 10s ease-in-out infinite;
    }

    .cta-shape-2 {
      width: 40px;
      height: 40px;
      border-radius: 8px;
      bottom: 15%;
      right: 5%;
      animation: ctaFloat2 13s ease-in-out infinite;
    }

    @keyframes ctaFloat1 {
      0%, 100% { transform: translate(0, 0) rotate(0deg); }
      50%      { transform: translate(-15px, 12px) rotate(180deg); }
    }

    @keyframes ctaFloat2 {
      0%, 100% { transform: rotate(0deg) translate(0, 0); }
      33%      { transform: rotate(120deg) translate(10px, -8px); }
      66%      { transform: rotate(240deg) translate(-8px, 10px); }
    }

    @media (prefers-reduced-motion: reduce) {
      .cta-marquee { animation: none; }
      .cta-shape { animation: none; }
    }

    /* ===== SECTION HEADINGS ===== */
    .section-head {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 1rem;
    }

    .sh-text {
      font-family: 'Bricolage Grotesque', Georgia, serif;
      font-size: clamp(2.25rem, 6vw, 4rem);
      font-weight: 800;
      line-height: 1.1;
      letter-spacing: -0.03em;
      color: var(--text);
      display: flex;
      flex-direction: column;
      gap: 0.05em;
    }

    .sh-quiet {
      color: var(--text-muted);
      font-weight: 400;
      font-size: 0.375em;
      letter-spacing: 0.08em;
      font-family: 'Space Grotesk', sans-serif;
      text-transform: uppercase;
    }

    .sh-loud {
      display: inline;
    }

    .sh-highlight {
      font-style: italic;
      color: var(--accent);
      position: relative;
    }

    .sh-highlight::after {
      content: '';
      position: absolute;
      bottom: 0.02em;
      left: -0.05em;
      right: -0.05em;
      height: 0.12em;
      background: var(--accent);
      opacity: 0.3;
      border-radius: 1em;
      transform: rotate(-1deg);
    }

    .sh-dot {
      color: var(--accent);
    }

    .sh-count {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.75rem;
      color: var(--text-muted);
      letter-spacing: 0.04em;
      white-space: nowrap;
      padding-bottom: 0.4em;
    }

    @media (max-width: 767px) {
      .sh-count {
        display: none;
      }
    }

    /* ===== TESTIMONIAL HEADING ===== */
    .testimonial-heading-text {
      font-family: 'Bricolage Grotesque', Georgia, serif;
      font-size: clamp(2.25rem, 6vw, 4rem);
      font-weight: 800;
      line-height: 1.1;
      letter-spacing: -0.03em;
      color: var(--text);
      display: flex;
      flex-direction: column;
      gap: 0.1em;
    }

    .th-line1 {
      color: var(--text-muted);
      font-weight: 400;
      font-size: 0.375em;
      letter-spacing: 0.08em;
      font-family: 'Space Grotesk', sans-serif;
      text-transform: uppercase;
    }

    .th-line2 {
      display: flex;
      align-items: baseline;
      gap: 0.25em;
      flex-wrap: wrap;
    }

    .th-my {
      font-style: italic;
      color: var(--accent);
      position: relative;
    }

    /* Scribble underline on "my" */
    .th-my::after {
      content: '';
      position: absolute;
      bottom: 0.02em;
      left: -0.05em;
      right: -0.05em;
      height: 0.12em;
      background: var(--accent);
      opacity: 0.3;
      border-radius: 1em;
      transform: rotate(-1.5deg);
    }

    .th-word-for-it {
      color: var(--text);
    }

    .th-arrow {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 1.2em;
      height: 1.2em;
      border-radius: 50%;
      border: 2px solid var(--border);
      color: var(--text-muted);
      font-size: 0.5em;
      flex-shrink: 0;
      transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1), border-color 0.3s ease, color 0.3s ease;
      animation: thBounce 3s ease-in-out infinite;
    }

    .testimonial-heading:hover .th-arrow {
      border-color: var(--accent);
      color: var(--accent);
      transform: rotate(0deg) scale(1.1);
    }

    @keyframes thBounce {
      0%, 100% { transform: translateY(0); }
      50%      { transform: translateY(-4px); }
    }

    @media (max-width: 767px) {
      .th-arrow {
        width: 1.4em;
        height: 1.4em;
      }

      .th-arrow svg {
        width: 18px;
        height: 18px;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .th-arrow { animation: none; }
    }
  </style>

  <script>
    function initCTA() {
      if (!window.matchMedia('(hover: hover)').matches) return;

      // Magnetic button
      document.querySelectorAll<HTMLElement>('[data-magnetic]').forEach((btn) => {
        const strength = 0.3;
        btn.addEventListener('mousemove', (e) => {
          const rect = btn.getBoundingClientRect();
          const x = e.clientX - rect.left - rect.width / 2;
          const y = e.clientY - rect.top - rect.height / 2;
          btn.style.transform = `translate(${x * strength}px, ${y * strength}px)`;
        });
        btn.addEventListener('mouseleave', () => {
          btn.style.transform = '';
        });
      });

      // CTA spotlight
      const ctaCard = document.querySelector<HTMLElement>('.cta-card');
      if (ctaCard) {
        ctaCard.addEventListener('mousemove', (e) => {
          const rect = ctaCard.getBoundingClientRect();
          ctaCard.style.setProperty('--cta-x', `${e.clientX - rect.left}px`);
          ctaCard.style.setProperty('--cta-y', `${e.clientY - rect.top}px`);
        });
      }
    }
    initCTA();
    document.addEventListener('astro:after-swap', initCTA);
  </script>
</PageLayout>
